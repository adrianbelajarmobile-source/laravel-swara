{
  "info": {
    "_postman_id": "event-management-2026",
    "name": "Event Management - Mobile API",
    "description": "Event Management API untuk Mobile Team - Check-in, Media, Progress tracking, Impact Reports",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Event Participation",
      "item": [
        {
          "name": "Join Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/join",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "join"]
            }
          }
        },
        {
          "name": "Check-In with QR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qr_token\": \"your-qr-token-here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/check-in",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "check-in"]
            }
          }
        },
        {
          "name": "Check-Out",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/participants/{{participant_id}}/check-out",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "participants", "{{participant_id}}", "check-out"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Media Management",
      "item": [
        {
          "name": "Upload Photo/Video",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "media_type",
                  "value": "photo",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "path/to/image.jpg"
                },
                {
                  "key": "participant_id",
                  "value": "{{participant_id}}",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Dokumentasi pembersihan",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/media",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "media"]
            }
          }
        },
        {
          "name": "List Media",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/media?media_type=photo&participant_id=&page=1&per_page=20",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "media"],
              "query": [
                {
                  "key": "media_type",
                  "value": "photo"
                },
                {
                  "key": "participant_id",
                  "value": ""
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/media/{{media_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "media", "{{media_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Progress & Monitoring",
      "item": [
        {
          "name": "Get Progress Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/progress",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "progress"]
            }
          }
        },
        {
          "name": "Get Participants List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/participants?status=all&sort_by=created_at&sort_order=desc&page=1&per_page=20",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "participants"],
              "query": [
                {
                  "key": "status",
                  "value": "all",
                  "description": "all, joined, checked_in, checked_out"
                },
                {
                  "key": "sort_by",
                  "value": "created_at"
                },
                {
                  "key": "sort_order",
                  "value": "desc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "5. Impact Reports",
      "item": [
        {
          "name": "Submit Impact Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activity_report\": \"Hari ini kami membersihkan sungai dan berhasil kumpulkan 2 ton sampah plastik\",\n  \"suggestions\": \"Lebih banyak sarung tangan dan waterproof bag yang lebih besar\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/impact-reports",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "impact-reports"]
            }
          }
        },
        {
          "name": "List Impact Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/impact-reports?sort_by=created_at&sort_order=desc&page=1",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "impact-reports"],
              "query": [
                {
                  "key": "sort_by",
                  "value": "created_at"
                },
                {
                  "key": "sort_order",
                  "value": "desc"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Impact Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/impact-reports/{{report_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "impact-reports", "{{report_id}}"]
            }
          }
        },
        {
          "name": "Update Impact Report",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activity_report\": \"Updated activity report content\",\n  \"suggestions\": \"Updated suggestions content\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/impact-reports/{{report_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "impact-reports", "{{report_id}}"]
            }
          }
        },
        {
          "name": "Delete Impact Report",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/events/{{event_id}}/impact-reports/{{report_id}}",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["api", "events", "{{event_id}}", "impact-reports", "{{report_id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your-sanctum-token-here",
      "type": "string"
    },
    {
      "key": "event_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "participant_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "media_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "report_id",
      "value": "1",
      "type": "string"
    }
  ]
}
